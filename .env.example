# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql://trials_user:trials_pass@localhost:5433/clinical_trials

# ClinicalTrials.gov API
API_BASE_URL=https://clinicaltrials.gov/api/v2
PAGE_SIZE=100

# How many studies to load (start small to test; increase later)
# 500 = quick demo, 5000 = medium, 0 = no limit (loads everything - takes hours)
MAX_STUDIES=5000
